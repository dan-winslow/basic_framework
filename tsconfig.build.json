{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/vite-env.d.ts", "src/index.ts", "src/app/components", "src/app/hooks"],
  "exclude": ["src/main.tsx", "src/app/pages", "src/app/layouts", "node_modules"]
}
